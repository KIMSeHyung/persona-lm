{
  "name": "persona-lm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "node --import tsx src/index.ts",
    "mcp:stdio": "node --import tsx src/mcp/stdio.ts",
    "persona:mirror": "node --import tsx src/runtime/prompt/run-persona-mirror.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "build": "tsup --config tsup.config.ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "db:push": "drizzle-kit push && pnpm db:bootstrap",
    "db:bootstrap": "node --import tsx src/db/bootstrap.ts",
    "db:seed": "node --import tsx src/db/seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
